<?xml version='1.0' encoding='utf-8'?>
<robot name="myobody">

  
  
  
  <material name="bone_material">
    <color rgba="0.8 0.85 0.8 1" />
  </material>
  <material name="skin_material">
    <color rgba="0.8 0.7 0.5 0.1" />
  </material>

  
  
  
  <link name="world" />

  
  
  
  <link name="root">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
  </link>

  <joint name="root_joint" type="floating">
    <parent link="world" />
    <child link="root" />
    <origin xyz="-0.025 0.1 1" rpy="0 0 0" />
  </joint>

  
  
  
  <link name="sacrum">
    <inertial>
      <origin xyz="-0.0707 0 0" rpy="0 0 0" />
      <mass value="0.500000" />
      <inertia ixx="0.0043644" ixy="0" ixz="0" iyy="0.0036979" iyz="0" izz="0.0024582" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/sacrum.stl" />
      </geometry>
      <material name="bone_material" />
    </visual>
  </link>

  <joint name="sacrum_to_root" type="fixed">
    <parent link="root" />
    <child link="sacrum" />
    
    <origin xyz="0 0 0" rpy="1.5708 0 0" />
  </joint>

  
  
  
  
  <link name="lumbar_extension_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001" />
    </inertial>
  </link>

  <joint name="lumbar_extension" type="revolute">
    <parent link="sacrum" />
    <child link="lumbar_extension_link" />
    <origin xyz="-0.1007 0.0815 0" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-0.8727" upper="0.2618" effort="1000" velocity="10" />
    <dynamics damping="0.5" />
  </joint>

  <link name="lumbar_bending_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
